<ui:FluentWindow x:Class="SysOpsCommander.App.Dialogs.CredentialDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="Enter Credentials"
        Height="340"
        Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ExtendsContentIntoTitleBar="True"
        AutomationProperties.Name="Credential Dialog">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <ui:TitleBar Grid.Row="0"
                     Title="Enter Credentials"
                     ShowMaximize="False"
                     ShowMinimize="False" />

        <!-- Domain -->
        <StackPanel Grid.Row="1" Margin="0,8,0,0">
            <TextBlock Text="Domain:" Margin="0,0,0,4" />
            <ui:TextBox Text="{Binding Domain, UpdateSourceTrigger=PropertyChanged}"
                        AutomationProperties.Name="Domain" />
        </StackPanel>

        <!-- Username -->
        <StackPanel Grid.Row="2" Margin="0,12,0,0">
            <TextBlock Text="Username:" Margin="0,0,0,4" />
            <ui:TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                        AutomationProperties.Name="Username" />
        </StackPanel>

        <!-- Password -->
        <StackPanel Grid.Row="3" Margin="0,12,0,0">
            <TextBlock Text="Password:" Margin="0,0,0,4" />
            <PasswordBox x:Name="PasswordInput"
                         AutomationProperties.Name="Password" />
        </StackPanel>

        <!-- Auth Method -->
        <StackPanel Grid.Row="4" Margin="0,12,0,0">
            <TextBlock Text="Auth Method:" Margin="0,0,0,4" />
            <ComboBox ItemsSource="{Binding AuthMethods}"
                      SelectedItem="{Binding SelectedAuthMethod}"
                      AutomationProperties.Name="Authentication Method" />
        </StackPanel>

        <!-- Spacer -->
        <Grid Grid.Row="5" />

        <!-- OK / Cancel -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <ui:Button Content="OK"
                       Click="OnOkClicked"
                       Appearance="Primary"
                       MinWidth="80"
                       AutomationProperties.Name="OK" />
            <ui:Button Content="Cancel"
                       Click="OnCancelClicked"
                       Margin="8,0,0,0"
                       MinWidth="80"
                       AutomationProperties.Name="Cancel" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>
