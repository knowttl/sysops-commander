<Window x:Class="SysOpsCommander.App.Dialogs.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Input"
        WindowStartupLocation="CenterOwner"
        SizeToContent="Height"
        Width="400"
        ResizeMode="NoResize"
        Background="{DynamicResource Surface1Brush}"
        ShowInTaskbar="False"
        AutomationProperties.Name="Input Dialog">

    <StackPanel Margin="20">
        <TextBlock x:Name="PromptText"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,10"
                   FontSize="13" />

        <TextBox x:Name="InputTextBox"
                 Style="{StaticResource ThemedTextBoxStyle}"
                 Margin="0,0,0,16"
                 FontSize="13"
                 Padding="6,4"
                 AutomationProperties.Name="Input Text" />

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="OK"
                    IsDefault="True"
                    Click="OkButton_Click"
                    Style="{StaticResource PrimaryButtonStyle}"
                    MinWidth="80"
                    Margin="0,0,8,0"
                    AutomationProperties.Name="OK" />
            <Button Content="Cancel"
                    IsCancel="True"
                    Style="{StaticResource SecondaryButtonStyle}"
                    MinWidth="80"
                    AutomationProperties.Name="Cancel" />
        </StackPanel>
    </StackPanel>
</Window>
