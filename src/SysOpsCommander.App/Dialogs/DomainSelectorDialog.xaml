<ui:FluentWindow x:Class="SysOpsCommander.App.Dialogs.DomainSelectorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="Connect to Domain"
        Height="280"
        Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ExtendsContentIntoTitleBar="True"
        AutomationProperties.Name="Domain Selector Dialog">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <ui:TitleBar Grid.Row="0"
                     Title="Connect to Domain"
                     ShowMaximize="False"
                     ShowMinimize="False" />

        <!-- Domain Name -->
        <StackPanel Grid.Row="1" Margin="0,8,0,0">
            <TextBlock Text="Domain Name:" Margin="0,0,0,4" />
            <ui:TextBox Text="{Binding DomainName, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="e.g., corp.contoso.com"
                        AutomationProperties.Name="Domain Name" />
        </StackPanel>

        <!-- Domain Controller -->
        <StackPanel Grid.Row="2" Margin="0,12,0,0">
            <TextBlock Text="Domain Controller (optional):" Margin="0,0,0,4" />
            <ui:TextBox Text="{Binding DomainControllerFqdn, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="e.g., dc01.corp.contoso.com"
                        AutomationProperties.Name="Domain Controller" />
        </StackPanel>

        <!-- Test Connection -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,16,0,0">
            <ui:Button Content="Test Connection"
                       Command="{Binding TestConnectionCommand}"
                       Appearance="Primary"
                       AutomationProperties.Name="Test Connection" />
            <TextBlock Text="{Binding TestStatus}"
                       VerticalAlignment="Center"
                       Margin="12,0,0,0" />
        </StackPanel>

        <!-- Spacer -->
        <Grid Grid.Row="5" />

        <!-- OK / Cancel -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <ui:Button Content="OK"
                       IsEnabled="{Binding IsTestSuccessful}"
                       Click="OnOkClicked"
                       Appearance="Primary"
                       MinWidth="80"
                       AutomationProperties.Name="OK" />
            <ui:Button Content="Cancel"
                       Click="OnCancelClicked"
                       Margin="8,0,0,0"
                       MinWidth="80"
                       AutomationProperties.Name="Cancel" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>
