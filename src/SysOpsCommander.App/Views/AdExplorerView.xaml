<UserControl x:Class="SysOpsCommander.App.Views.AdExplorerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:vm="clr-namespace:SysOpsCommander.ViewModels;assembly=SysOpsCommander.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1200"
             d:DataContext="{d:DesignInstance Type=vm:AdExplorerViewModel}"
             AutomationProperties.Name="AD Explorer View">

    <!-- Keyboard shortcuts -->
    <UserControl.InputBindings>
        <KeyBinding Key="D1" Modifiers="Control" Command="{Binding ToggleZone1Command}" />
        <KeyBinding Key="D3" Modifiers="Control" Command="{Binding ToggleZone3Command}" />
        <KeyBinding Key="Escape" Command="{Binding CollapseInspectorCommand}" />
        <KeyBinding Key="C" Modifiers="Control" Command="{Binding CopyToClipboardCommand}" />
    </UserControl.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="28" />
        </Grid.RowDefinitions>

        <!-- Main 4-zone layout -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="Zone1Column" Width="280" MinWidth="40" MaxWidth="450" />
                <ColumnDefinition x:Name="Splitter1Column" Width="Auto" />
                <ColumnDefinition x:Name="Zone2Column" Width="*" />
                <ColumnDefinition x:Name="Splitter3Column" Width="Auto" />
                <ColumnDefinition x:Name="Zone3Column" Width="320" MinWidth="40" MaxWidth="600" />
            </Grid.ColumnDefinitions>

            <!-- ═══════════════════════════════════════════════════ -->
            <!--  ZONE 1 — OU Navigator (Left Panel)               -->
            <!-- ═══════════════════════════════════════════════════ -->
            <Border Grid.Column="0"
                    Style="{StaticResource ZonePanelBorderStyle}">
                <Grid>
                    <!-- Expanded content -->
                    <Grid Visibility="{Binding IsZone1Collapsed, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=invert}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Panel header -->
                        <Border Grid.Row="0" Style="{StaticResource PanelHeaderBorderStyle}">
                            <DockPanel>
                                <TextBlock Text="OU Navigator"
                                           Style="{StaticResource PanelTitleStyle}"
                                           VerticalAlignment="Center" />
                                <Button DockPanel.Dock="Right"
                                        HorizontalAlignment="Right"
                                        Command="{Binding ToggleZone1Command}"
                                        Style="{StaticResource PanelChevronButtonStyle}"
                                        AutomationProperties.Name="Collapse OU Navigator"
                                        ToolTip="Collapse (Ctrl+1)">
                                    <TextBlock Text="&#xE76B;" FontFamily="Segoe MDL2 Assets" FontSize="10" />
                                </Button>
                            </DockPanel>
                        </Border>

                    <!-- Load Tree button -->
                    <Button Grid.Row="1"
                            Command="{Binding LoadTreeRootCommand}"
                            HorizontalAlignment="Stretch"
                            Margin="6,6,6,2"
                            AutomationProperties.Name="Load AD Tree">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE774;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="14"
                                       VerticalAlignment="Center"
                                       Margin="0,0,6,0" />
                            <TextBlock Text="Load Tree" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <!-- Tree search/filter box -->
                    <TextBox Grid.Row="2"
                             Margin="6,4,6,4"
                             Style="{StaticResource ThemedTextBoxStyle}"
                             Text="{Binding TreeFilterText, UpdateSourceTrigger=PropertyChanged}"
                             x:Name="TreeFilterTextBox"
                             AutomationProperties.Name="Filter OUs">
                        <TextBox.ToolTip>
                            <ToolTip Style="{StaticResource ThemedToolTipStyle}"
                                     Content="Type to filter the OU tree" />
                        </TextBox.ToolTip>
                    </TextBox>

                    <!-- Breadcrumb bar -->
                    <ItemsControl Grid.Row="3"
                                  ItemsSource="{Binding BreadcrumbSegments}"
                                  Margin="6,0,6,4"
                                  AutomationProperties.Name="Breadcrumb Navigation">
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding BreadcrumbSegments.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="{Binding Label}"
                                            Command="{Binding DataContext.NavigateToBreadcrumbCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding DistinguishedName}"
                                            FontSize="10"
                                            Padding="2,1"
                                            Background="Transparent"
                                            Foreground="{DynamicResource AccentBlueBrush}"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            ToolTip="{Binding DistinguishedName}" />
                                    <TextBlock Text=" ›"
                                               Foreground="{DynamicResource TextTertiaryBrush}"
                                               FontSize="10"
                                               VerticalAlignment="Center"
                                               Margin="2,0" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- OU TreeView -->
                    <TreeView Grid.Row="4"
                              ItemsSource="{Binding FilteredTreeNodes}"
                              AutomationProperties.Name="AD Object Tree"
                              x:Name="AdTreeView"
                              VirtualizingStackPanel.IsVirtualizing="True"
                              VirtualizingStackPanel.VirtualizationMode="Recycling"
                              Background="Transparent"
                              BorderThickness="0"
                              Margin="2,0,2,2">
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal" Margin="2,1">
                                    <StackPanel.ContextMenu>
                                        <ContextMenu Style="{StaticResource ThemedContextMenuStyle}">
                                            <MenuItem Header="Copy OU Path"
                                                      Click="CopyOuPath_Click"
                                                      AutomationProperties.Name="Copy OU Path" />
                                        </ContextMenu>
                                    </StackPanel.ContextMenu>
                                    <TextBlock Text="{Binding ObjectClass, Converter={StaticResource ObjectClassToIconConverter}}"
                                               Foreground="{Binding ObjectClass, Converter={StaticResource ObjectClassToIconColorConverter}}"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="14"
                                               VerticalAlignment="Center"
                                               Margin="0,0,6,0" />
                                    <TextBlock Text="{Binding Name}"
                                               Style="{StaticResource BodyTextStyle}"
                                               VerticalAlignment="Center" />
                                    <TextBlock VerticalAlignment="Center"
                                               Margin="4,0,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource CaptionStyle}">
                                                <Setter Property="Foreground" Value="{DynamicResource TextTertiaryBrush}" />
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Children.Count}" Value="0">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                        <TextBlock.Text>
                                            <Binding Path="Children.Count" StringFormat=" ({0})" />
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                                <Setter Property="Padding" Value="4,3" />
                                <Setter Property="Margin" Value="0,1" />
                                <Setter Property="MinHeight" Value="26" />
                            </Style>
                        </TreeView.ItemContainerStyle>
                    </TreeView>
                    </Grid>

                    <!-- Collapsed rail (40px icon strip) -->
                    <StackPanel Visibility="{Binding IsZone1Collapsed, Converter={StaticResource BoolToVisibilityConverter}}"
                                HorizontalAlignment="Center"
                                Margin="0,8,0,0">
                        <Button Command="{Binding ToggleZone1Command}"
                                Style="{StaticResource PanelChevronButtonStyle}"
                                AutomationProperties.Name="Expand OU Navigator"
                                ToolTip="Expand (Ctrl+1)"
                                Margin="0,0,0,12">
                            <TextBlock Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="10" />
                        </Button>
                        <TextBlock Text="&#xE774;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="16"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- GridSplitter: Zone 1 | Zone 2 -->
            <GridSplitter Grid.Column="1"
                          x:Name="Splitter1"
                          IsEnabled="{Binding IsZone1Collapsed, Converter={StaticResource InverseBoolConverter}}"
                          Style="{StaticResource ThemedGridSplitterStyle}" />

            <!-- ═══════════════════════════════════════════════════ -->
            <!--  ZONE 2 — Tabbed Workspace (Center Panel)         -->
            <!-- ═══════════════════════════════════════════════════ -->
            <Border Grid.Column="2"
                    Style="{StaticResource ZonePanelBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Domain badge + Send to Targets -->
                    <DockPanel Grid.Row="0" Margin="8,6,8,2">
                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- Back (undo) button -->
                            <Button Command="{Binding GoBackCommand}"
                                    Style="{StaticResource PanelChevronButtonStyle}"
                                    ToolTip="Go back to previous search results"
                                    Padding="6,4" Margin="0,0,6,0"
                                    AutomationProperties.Name="Go Back">
                                <Button.IsEnabled>
                                    <Binding Path="CanGoBack" />
                                </Button.IsEnabled>
                                <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="14" />
                            </Button>
                            <TextBlock Text="AD Explorer"
                                       Style="{StaticResource PanelTitleStyle}"
                                       VerticalAlignment="Center" />
                            <Border Background="{DynamicResource Surface2Brush}"
                                    BorderBrush="{DynamicResource BorderDefaultBrush}"
                                    BorderThickness="1" CornerRadius="4"
                                    Padding="8,3" Margin="10,0,0,0"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding ActiveDomainDisplay, Converter={StaticResource StringToVisibilityConverter}}"
                                    AutomationProperties.Name="Active Domain Badge">
                                <TextBlock Text="{Binding ActiveDomainDisplay}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextAccentBrush}"
                                           FontSize="11.5" />
                            </Border>
                        </StackPanel>
                        <Button DockPanel.Dock="Right"
                                Content="Send to Targets"
                                HorizontalAlignment="Right"
                                Command="{Binding SendToExecutionTargetsCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                AutomationProperties.Name="Send to Execution Targets" />
                    </DockPanel>

                    <!-- Security Filter Buttons -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="8,4,8,4">
                        <TextBlock Text="Security Filters:"
                                   Style="{StaticResource LabelStyle}"
                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                        <Button Content="Locked Accounts"
                                Command="{Binding GetLockedAccountsCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0,0,4,0" Padding="10,4"
                                AutomationProperties.Name="Get Locked Accounts" />
                        <Button Content="Disabled Computers"
                                Command="{Binding GetDisabledComputersCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0,0,4,0" Padding="10,4"
                                AutomationProperties.Name="Get Disabled Computers" />
                        <Button Content="Stale Computers"
                                Command="{Binding GetStaleComputersCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0,0,4,0" Padding="10,4"
                                AutomationProperties.Name="Get Stale Computers" />
                        <Button Content="Domain Controllers"
                                Command="{Binding GetDomainControllersCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Padding="10,4"
                                AutomationProperties.Name="Get Domain Controllers" />
                    </StackPanel>

                    <!-- Advanced search bar -->
                    <StackPanel Grid.Row="2" Margin="8,2,8,6">

                        <!-- Simple mode: Attribute selector + search input + buttons -->
                        <Grid Visibility="{Binding IsLdapFilterMode, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=invert}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ComboBox Grid.Column="0"
                                      ItemsSource="{Binding AttributeOptions}"
                                      SelectedItem="{Binding SelectedAttribute}"
                                      MinWidth="130"
                                      Margin="0,0,6,0"
                                      VerticalContentAlignment="Center"
                                      AutomationProperties.Name="Attribute Filter" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ThemedTextBoxStyle}"
                                     x:Name="SearchTextBox"
                                     AutomationProperties.Name="AD Search Box" />

                            <!-- Search history dropdown -->
                            <ToggleButton Grid.Column="2"
                                          IsChecked="{Binding IsSearchHistoryOpen}"
                                          Style="{StaticResource PanelChevronToggleButtonStyle}"
                                          Margin="2,0,0,0"
                                          Width="24" Height="24"
                                          ToolTip="Search history"
                                          AutomationProperties.Name="Search History">
                                <TextBlock Text="&#xE81C;" FontFamily="Segoe MDL2 Assets" FontSize="11" />
                            </ToggleButton>

                            <!-- Search button -->
                            <Button Grid.Column="3"
                                    Command="{Binding SearchCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Margin="4,0,0,0"
                                    AutomationProperties.Name="Search Button">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE721;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               Margin="0,0,6,0" />
                                    <TextBlock Text="Search" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <!-- Save search (star) button -->
                            <ToggleButton Grid.Column="4"
                                          IsChecked="{Binding IsSavedSearchesOpen}"
                                          Style="{StaticResource PanelChevronToggleButtonStyle}"
                                          Margin="4,0,0,0"
                                          Width="24" Height="24"
                                          ToolTip="Saved searches"
                                          AutomationProperties.Name="Saved Searches">
                                <TextBlock Text="&#xE734;" FontFamily="Segoe MDL2 Assets" FontSize="13" />
                            </ToggleButton>

                            <!-- LDAP mode toggle -->
                            <ToggleButton Grid.Column="5"
                                          IsChecked="{Binding IsLdapFilterMode, Mode=OneWay}"
                                          Command="{Binding ToggleLdapFilterModeCommand}"
                                          Style="{StaticResource FilterPillStyle}"
                                          Margin="4,0,0,0"
                                          Padding="6,3"
                                          ToolTip="Toggle raw LDAP filter mode"
                                          AutomationProperties.Name="LDAP Filter Mode">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE943;" FontFamily="Segoe MDL2 Assets" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0" />
                                    <TextBlock Text="LDAP" VerticalAlignment="Center" FontSize="11" />
                                </StackPanel>
                            </ToggleButton>
                        </Grid>

                        <!-- LDAP filter mode: multi-line TextBox + search button -->
                        <Grid Visibility="{Binding IsLdapFilterMode, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBox Grid.Column="0" Grid.Row="0"
                                     Text="{Binding RawLdapFilter, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ThemedTextBoxStyle}"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     MinHeight="60"
                                     MaxHeight="100"
                                     VerticalScrollBarVisibility="Auto"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     AutomationProperties.Name="LDAP Filter Input">
                                <TextBox.ToolTip>
                                    <ToolTip Style="{StaticResource ThemedToolTipStyle}"
                                             Content="Enter a raw LDAP filter, e.g. (&amp;(objectClass=user)(department=IT))" />
                                </TextBox.ToolTip>
                            </TextBox>

                            <StackPanel Grid.Column="1" Grid.Row="0"
                                        VerticalAlignment="Top"
                                        Margin="4,0,0,0">
                                <Button Command="{Binding SearchCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Margin="0,0,0,4"
                                        AutomationProperties.Name="Search LDAP Filter">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0" />
                                        <TextBlock Text="Search" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <ToggleButton IsChecked="{Binding IsLdapFilterMode, Mode=OneWay}"
                                              Command="{Binding ToggleLdapFilterModeCommand}"
                                              Style="{StaticResource FilterPillStyle}"
                                              Padding="6,3"
                                              ToolTip="Switch to simple search"
                                              AutomationProperties.Name="Switch to Simple Mode">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE943;" FontFamily="Segoe MDL2 Assets" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0" />
                                        <TextBlock Text="Simple" VerticalAlignment="Center" FontSize="11" />
                                    </StackPanel>
                                </ToggleButton>
                            </StackPanel>
                        </Grid>

                        <!-- Object class filter pills (hidden in LDAP mode) -->
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0"
                                    Visibility="{Binding IsLdapFilterMode, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=invert}">
                            <ToggleButton IsChecked="{Binding FilterAll, Mode=OneWay}"
                                          Command="{Binding ToggleFilterCommand}"
                                          CommandParameter="All"
                                          Style="{StaticResource FilterPillStyle}"
                                          Content="All"
                                          Margin="0,0,4,0"
                                          AutomationProperties.Name="Filter All" />
                            <ToggleButton IsChecked="{Binding FilterUsers, Mode=OneWay}"
                                          Command="{Binding ToggleFilterCommand}"
                                          CommandParameter="user"
                                          Style="{StaticResource FilterPillStyle}"
                                          Margin="0,0,4,0"
                                          AutomationProperties.Name="Filter Users">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0" />
                                    <TextBlock Text="Users" VerticalAlignment="Center" />
                                </StackPanel>
                            </ToggleButton>
                            <ToggleButton IsChecked="{Binding FilterComputers, Mode=OneWay}"
                                          Command="{Binding ToggleFilterCommand}"
                                          CommandParameter="computer"
                                          Style="{StaticResource FilterPillStyle}"
                                          Margin="0,0,4,0"
                                          AutomationProperties.Name="Filter Computers">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE7F8;" FontFamily="Segoe MDL2 Assets" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0" />
                                    <TextBlock Text="Computers" VerticalAlignment="Center" />
                                </StackPanel>
                            </ToggleButton>
                            <ToggleButton IsChecked="{Binding FilterGroups, Mode=OneWay}"
                                          Command="{Binding ToggleFilterCommand}"
                                          CommandParameter="group"
                                          Style="{StaticResource FilterPillStyle}"
                                          Margin="0,0,4,0"
                                          AutomationProperties.Name="Filter Groups">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0" />
                                    <TextBlock Text="Groups" VerticalAlignment="Center" />
                                </StackPanel>
                            </ToggleButton>
                            <ToggleButton IsChecked="{Binding FilterOus, Mode=OneWay}"
                                          Command="{Binding ToggleFilterCommand}"
                                          CommandParameter="organizationalUnit"
                                          Style="{StaticResource FilterPillStyle}"
                                          Margin="0,0,4,0"
                                          AutomationProperties.Name="Filter OUs">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xED41;" FontFamily="Segoe MDL2 Assets" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0" />
                                    <TextBlock Text="OUs" VerticalAlignment="Center" />
                                </StackPanel>
                            </ToggleButton>
                        </StackPanel>

                        <!-- Search history popup -->
                        <Popup IsOpen="{Binding IsSearchHistoryOpen}"
                               StaysOpen="False"
                               Placement="Bottom"
                               PlacementTarget="{Binding ElementName=SearchTextBox}"
                               AllowsTransparency="True"
                               PopupAnimation="Fade"
                               AutomationProperties.Name="Search History Popup">
                            <Border Background="{DynamicResource Surface2Brush}"
                                    BorderBrush="{DynamicResource BorderDefaultBrush}"
                                    BorderThickness="1" CornerRadius="4"
                                    Padding="4" MinWidth="350" MaxHeight="320">
                                <DockPanel>
                                    <DockPanel DockPanel.Dock="Top" Margin="4,2,4,4">
                                        <TextBlock Text="Search History"
                                                   Style="{StaticResource LabelStyle}"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center" />
                                        <Button DockPanel.Dock="Right"
                                                Content="Clear"
                                                Command="{Binding ClearSearchHistoryCommand}"
                                                HorizontalAlignment="Right"
                                                FontSize="11" Padding="6,2"
                                                Background="Transparent"
                                                Foreground="{DynamicResource TextSecondaryBrush}"
                                                BorderThickness="0" Cursor="Hand"
                                                AutomationProperties.Name="Clear History" />
                                    </DockPanel>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding SearchHistory}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Command="{Binding DataContext.ExecuteHistoryEntryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            HorizontalContentAlignment="Stretch"
                                                            Cursor="Hand"
                                                            Padding="6,4" Margin="0,1">
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding QueryText}"
                                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                                       FontWeight="SemiBold"
                                                                       FontSize="12"
                                                                       TextTrimming="CharacterEllipsis" />
                                                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                                <TextBlock Text="{Binding SelectedAttribute}"
                                                                           Foreground="{DynamicResource TextTertiaryBrush}"
                                                                           FontSize="10.5" Margin="0,0,8,0" />
                                                                <TextBlock Text="{Binding ResultCount, StringFormat='{}{0} results'}"
                                                                           Foreground="{DynamicResource TextTertiaryBrush}"
                                                                           FontSize="10.5" Margin="0,0,8,0" />
                                                                <TextBlock Text="{Binding ExecutedAtUtc, StringFormat='{}{0:g}', ConverterCulture=en-US}"
                                                                           Foreground="{DynamicResource TextTertiaryBrush}"
                                                                           FontSize="10.5" />
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </DockPanel>
                            </Border>
                        </Popup>

                        <!-- Saved searches popup -->
                        <Popup IsOpen="{Binding IsSavedSearchesOpen}"
                               StaysOpen="False"
                               Placement="Bottom"
                               PlacementTarget="{Binding ElementName=SearchTextBox}"
                               AllowsTransparency="True"
                               PopupAnimation="Fade"
                               AutomationProperties.Name="Saved Searches Popup">
                            <Border Background="{DynamicResource Surface2Brush}"
                                    BorderBrush="{DynamicResource BorderDefaultBrush}"
                                    BorderThickness="1" CornerRadius="4"
                                    Padding="4" MinWidth="350" MaxHeight="320">
                                <DockPanel>
                                    <Button DockPanel.Dock="Top"
                                            Command="{Binding SaveCurrentSearchCommand}"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            HorizontalContentAlignment="Left"
                                            Cursor="Hand"
                                            Padding="6,4" Margin="0,2,0,4"
                                            AutomationProperties.Name="Save Current Search">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"
                                                       Foreground="{DynamicResource AccentBlueBrush}" />
                                            <TextBlock Text="Save current search"
                                                       Foreground="{DynamicResource AccentBlueBrush}"
                                                       FontSize="12" />
                                        </StackPanel>
                                    </Button>
                                    <Separator DockPanel.Dock="Top"
                                               Background="{DynamicResource BorderSubtleBrush}"
                                               Margin="4,0,4,4" />
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding SavedSearches}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Command="{Binding DataContext.ExecuteSavedSearchCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            HorizontalContentAlignment="Stretch"
                                                            Cursor="Hand"
                                                            Padding="6,4" Margin="0,1">
                                                        <Button.ContextMenu>
                                                            <ContextMenu Style="{StaticResource ThemedContextMenuStyle}">
                                                                <MenuItem Header="Rename"
                                                                          Click="RenameSavedSearch_Click"
                                                                          AutomationProperties.Name="Rename Saved Search" />
                                                                <MenuItem Header="Delete"
                                                                          Click="DeleteSavedSearch_Click"
                                                                          AutomationProperties.Name="Delete Saved Search" />
                                                            </ContextMenu>
                                                        </Button.ContextMenu>
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Name}"
                                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                                       FontWeight="SemiBold"
                                                                       FontSize="12"
                                                                       TextTrimming="CharacterEllipsis" />
                                                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                                <TextBlock Text="{Binding QueryText}"
                                                                           Foreground="{DynamicResource TextTertiaryBrush}"
                                                                           FontSize="10.5"
                                                                           MaxWidth="200"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           Margin="0,0,8,0" />
                                                                <TextBlock Text="{Binding SelectedAttribute}"
                                                                           Foreground="{DynamicResource TextTertiaryBrush}"
                                                                           FontSize="10.5" />
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                    <!-- Empty state -->
                                    <TextBlock Text="No saved searches yet"
                                               HorizontalAlignment="Center"
                                               Margin="0,8,0,8">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource CaptionStyle}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SavedSearches.Count}" Value="0">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DockPanel>
                            </Border>
                        </Popup>

                        <!-- Row 3: Scope context line -->
                        <DockPanel Margin="0,4,0,0">
                            <CheckBox DockPanel.Dock="Right"
                                      Content="Entire domain"
                                      IsChecked="{Binding SearchEntireDomain}"
                                      Foreground="{DynamicResource TextSecondaryBrush}"
                                      FontSize="11"
                                      VerticalContentAlignment="Center"
                                      AutomationProperties.Name="Search Entire Domain" />
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Scope:"
                                           Style="{StaticResource CaptionStyle}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,4,0" />
                                <TextBlock VerticalAlignment="Center"
                                           FontSize="11"
                                           Foreground="{DynamicResource AccentBlueBrush}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{Binding ScopeDisplay}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SearchEntireDomain}" Value="True">
                                                    <Setter Property="Text" Value="Domain root" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <Button Content="Reset"
                                        Command="{Binding ResetScopeCommand}"
                                        FontSize="11"
                                        Padding="6,1"
                                        Margin="6,0,0,0"
                                        Background="Transparent"
                                        Foreground="{DynamicResource TextSecondaryBrush}"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        AutomationProperties.Name="Reset Scope">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ScopeDisplay}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding ScopeDisplay}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>
                        </DockPanel>
                    </StackPanel>

                    <!-- Search Results DataGrid -->
                    <Grid Grid.Row="3" Margin="4,0,4,0">
                        <DataGrid ItemsSource="{Binding SearchResults}"
                                  SelectedItem="{Binding SelectedObject}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  SelectionMode="Single"
                                  SelectionUnit="FullRow"
                                  CanUserSortColumns="True"
                                  CanUserResizeColumns="True"
                                  CanUserReorderColumns="True"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  RowHeight="28"
                                  AutomationProperties.Name="AD Search Results">
                            <DataGrid.ContextMenu>
                                <ContextMenu Style="{StaticResource ThemedContextMenuStyle}">
                                    <MenuItem Header="Scope search to this OU"
                                              Command="{Binding ScopeToSelectedOuCommand}"
                                              AutomationProperties.Name="Scope To OU" />
                                    <MenuItem Header="Show group members"
                                              Command="{Binding ShowGroupMembersCommand}"
                                              AutomationProperties.Name="Show Group Members" />
                                    <Separator />
                                    <MenuItem Header="Send computers to execution targets"
                                              Command="{Binding SendToExecutionTargetsCommand}"
                                              AutomationProperties.Name="Send To Targets" />
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="Name" Width="*" SortMemberPath="Name"
                                                        Visibility="{Binding DataContext.DataGridColumns[0].IsVisible, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding Name, Mode=OneWay}" IsReadOnly="True" IsReadOnlyCaretVisible="True"
                                                     Background="Transparent" BorderThickness="0" Padding="4,2"
                                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                                     ContextMenu="{x:Null}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Class" Width="100" SortMemberPath="ObjectClass"
                                                        Visibility="{Binding DataContext.DataGridColumns[1].IsVisible, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding ObjectClass, Mode=OneWay}" IsReadOnly="True" IsReadOnlyCaretVisible="True"
                                                     Background="Transparent" BorderThickness="0" Padding="4,2"
                                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                                     ContextMenu="{x:Null}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Description" Width="*" SortMemberPath="Description"
                                                        Visibility="{Binding DataContext.DataGridColumns[2].IsVisible, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding Description, Mode=OneWay}" IsReadOnly="True" IsReadOnlyCaretVisible="True"
                                                     Background="Transparent" BorderThickness="0" Padding="4,2"
                                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                                     ContextMenu="{x:Null}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Distinguished Name" Width="2*" SortMemberPath="DistinguishedName"
                                                        Visibility="{Binding DataContext.DataGridColumns[3].IsVisible, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding DistinguishedName, Mode=OneWay}" IsReadOnly="True" IsReadOnlyCaretVisible="True"
                                                     Background="Transparent" BorderThickness="0" Padding="4,2"
                                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                                     ContextMenu="{x:Null}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Search progress bar -->
                        <ProgressBar IsIndeterminate="True"
                                     Height="3"
                                     VerticalAlignment="Top"
                                     Foreground="{DynamicResource AccentBlueBrush}"
                                     Visibility="{Binding IsSearching, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <!-- Empty state -->
                        <TextBlock Text="Search for Active Directory objects using the bar above"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   AutomationProperties.Name="Empty State Message">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource CaptionStyle}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SearchResults.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <!-- Footer: result count + export -->
                    <Border Grid.Row="4" Padding="8,4"
                            Background="{DynamicResource Surface2Brush}"
                            CornerRadius="0,0,4,4">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Right"
                                       Text="{Binding ResultStatus}"
                                       Style="{StaticResource CaptionStyle}"
                                       HorizontalAlignment="Right" />

                            <!-- Export button -->
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="0,0,12,0">
                                <!-- Column picker gear button -->
                                <Button x:Name="ColumnPickerButton"
                                        Command="{Binding ToggleColumnPickerCommand}"
                                        Style="{StaticResource PanelChevronButtonStyle}"
                                        Padding="4,2" Margin="0,0,6,0"
                                        ToolTip="Show/hide columns"
                                        AutomationProperties.Name="Column Picker">
                                    <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="12" />
                                </Button>

                                <!-- Column picker popup -->
                                <Popup IsOpen="{Binding IsColumnPickerOpen}"
                                       StaysOpen="False"
                                       Placement="Top"
                                       PlacementTarget="{Binding ElementName=ColumnPickerButton}"
                                       AllowsTransparency="True"
                                       PopupAnimation="Fade"
                                       AutomationProperties.Name="Column Visibility Picker">
                                    <Border Background="{DynamicResource Surface2Brush}"
                                            BorderBrush="{DynamicResource BorderDefaultBrush}"
                                            BorderThickness="1" CornerRadius="4"
                                            Padding="8" MinWidth="180">
                                        <StackPanel>
                                            <TextBlock Text="Visible Columns"
                                                       Style="{StaticResource LabelStyle}"
                                                       FontWeight="SemiBold"
                                                       Margin="0,0,0,6" />
                                            <ItemsControl ItemsSource="{Binding DataGridColumns}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <CheckBox IsChecked="{Binding IsVisible}"
                                                                  Content="{Binding Header}"
                                                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                                                  FontSize="11.5"
                                                                  Margin="0,2" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </Popup>

                                <Button x:Name="ExportButton"
                                        Command="{Binding ShowExportMenuCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Padding="8,2" FontSize="11"
                                        AutomationProperties.Name="Export Results">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xEDE1;" FontFamily="Segoe MDL2 Assets" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0" />
                                        <TextBlock Text="Export" VerticalAlignment="Center" />
                                        <TextBlock Text=" ▾" VerticalAlignment="Center" FontSize="9" />
                                    </StackPanel>
                                </Button>

                                <!-- Export menu popup -->
                                <Popup IsOpen="{Binding IsExportMenuOpen}"
                                       StaysOpen="False"
                                       Placement="Top"
                                       PlacementTarget="{Binding ElementName=ExportButton}"
                                       AllowsTransparency="True"
                                       PopupAnimation="Fade"
                                       AutomationProperties.Name="Export Menu">
                                    <Border Background="{DynamicResource Surface2Brush}"
                                            BorderBrush="{DynamicResource BorderDefaultBrush}"
                                            BorderThickness="1" CornerRadius="4"
                                            Padding="2" MinWidth="180">
                                        <StackPanel>
                                            <Button Command="{Binding CopyToClipboardCommand}"
                                                    Background="Transparent" BorderThickness="0"
                                                    HorizontalContentAlignment="Left" Cursor="Hand"
                                                    Padding="8,5"
                                                    AutomationProperties.Name="Copy to Clipboard">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0" />
                                                    <TextBlock Text="Copy to Clipboard" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" />
                                                    <TextBlock Text="  Ctrl+C" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="10.5" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                            <Separator Background="{DynamicResource BorderSubtleBrush}" Margin="4,1" />
                                            <Button Command="{Binding StartCsvExportCommand}"
                                                    Background="Transparent" BorderThickness="0"
                                                    HorizontalContentAlignment="Left" Cursor="Hand"
                                                    Padding="8,5"
                                                    AutomationProperties.Name="Export to CSV">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE9F9;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0" />
                                                    <TextBlock Text="Export to CSV..." Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" />
                                                </StackPanel>
                                            </Button>
                                            <Button Command="{Binding StartExcelExportCommand}"
                                                    Background="Transparent" BorderThickness="0"
                                                    HorizontalContentAlignment="Left" Cursor="Hand"
                                                    Padding="8,5"
                                                    AutomationProperties.Name="Export to Excel">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE9F9;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0" />
                                                    <TextBlock Text="Export to Excel..." Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                </Popup>

                                <!-- Export column picker popup -->
                                <Popup IsOpen="{Binding IsExportColumnPickerOpen}"
                                       StaysOpen="True"
                                       Placement="Top"
                                       PlacementTarget="{Binding ElementName=ExportButton}"
                                       AllowsTransparency="True"
                                       PopupAnimation="Fade"
                                       AutomationProperties.Name="Column Picker">
                                    <Border Background="{DynamicResource Surface2Brush}"
                                            BorderBrush="{DynamicResource BorderDefaultBrush}"
                                            BorderThickness="1" CornerRadius="4"
                                            Padding="8" MinWidth="280" MaxHeight="400">
                                        <DockPanel>
                                            <TextBlock DockPanel.Dock="Top"
                                                       Text="Select columns to export"
                                                       Style="{StaticResource LabelStyle}"
                                                       FontWeight="SemiBold"
                                                       Margin="0,0,0,6" />
                                            <StackPanel DockPanel.Dock="Top"
                                                        Orientation="Horizontal" Margin="0,0,0,6">
                                                <Button Content="Select All"
                                                        Command="{Binding SelectAllExportColumnsCommand}"
                                                        FontSize="11" Padding="6,2"
                                                        Background="Transparent" BorderThickness="0"
                                                        Foreground="{DynamicResource AccentBlueBrush}"
                                                        Cursor="Hand" Margin="0,0,8,0"
                                                        AutomationProperties.Name="Select All Columns" />
                                                <Button Content="Deselect All"
                                                        Command="{Binding DeselectAllExportColumnsCommand}"
                                                        FontSize="11" Padding="6,2"
                                                        Background="Transparent" BorderThickness="0"
                                                        Foreground="{DynamicResource AccentBlueBrush}"
                                                        Cursor="Hand"
                                                        AutomationProperties.Name="Deselect All Columns" />
                                            </StackPanel>
                                            <StackPanel DockPanel.Dock="Bottom"
                                                        Orientation="Horizontal"
                                                        HorizontalAlignment="Right"
                                                        Margin="0,6,0,0">
                                                <Button Content="Export"
                                                        Command="{Binding ConfirmExportCommand}"
                                                        Style="{StaticResource PrimaryButtonStyle}"
                                                        Padding="12,4" Margin="0,0,6,0"
                                                        AutomationProperties.Name="Confirm Export" />
                                                <Button Content="Cancel"
                                                        Command="{Binding CancelExportCommand}"
                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                        Padding="12,4"
                                                        AutomationProperties.Name="Cancel Export" />
                                            </StackPanel>
                                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                          MaxHeight="250">
                                                <ItemsControl ItemsSource="{Binding AvailableExportColumns}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <CheckBox IsChecked="{Binding IsSelected}"
                                                                      Content="{Binding ColumnName}"
                                                                      Foreground="{DynamicResource TextPrimaryBrush}"
                                                                      FontSize="11.5"
                                                                      Margin="0,1" />
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </DockPanel>
                                    </Border>
                                </Popup>
                            </StackPanel>

                            <TextBlock Text="{Binding SearchResults.Count, StringFormat='{}{0} results'}"
                                       Style="{StaticResource CaptionStyle}" />
                        </DockPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- GridSplitter: Zone 2 | Zone 3 -->
            <GridSplitter Grid.Column="3"
                          x:Name="Splitter3"
                          IsEnabled="{Binding IsZone3Collapsed, Converter={StaticResource InverseBoolConverter}}"
                          Style="{StaticResource ThemedGridSplitterStyle}" />

            <!-- ═══════════════════════════════════════════════════ -->
            <!--  ZONE 3 — Detail Inspector (Right Panel)          -->
            <!-- ═══════════════════════════════════════════════════ -->
            <Border Grid.Column="4"
                    Style="{StaticResource ZonePanelBorderStyle}">
                <Grid>
                    <!-- Expanded content -->
                    <Grid Visibility="{Binding IsZone3Collapsed, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=invert}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Panel header -->
                        <Border Grid.Row="0" Style="{StaticResource PanelHeaderBorderStyle}">
                            <DockPanel>
                                <TextBlock Text="Detail Inspector"
                                           Style="{StaticResource PanelTitleStyle}"
                                           VerticalAlignment="Center" />
                                <StackPanel DockPanel.Dock="Right"
                                            Orientation="Horizontal"
                                            HorizontalAlignment="Right">
                                    <Button Command="{Binding ExpandInspectorCommand}"
                                            Style="{StaticResource PanelChevronButtonStyle}"
                                            AutomationProperties.Name="Expand Detail Inspector"
                                            ToolTip="Expand to full width"
                                            Visibility="{Binding IsInspectorExpanded, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=invert}">
                                        <TextBlock Text="&#xE740;" FontFamily="Segoe MDL2 Assets" FontSize="10" />
                                    </Button>
                                    <Button Command="{Binding CollapseInspectorCommand}"
                                            Style="{StaticResource PanelChevronButtonStyle}"
                                            AutomationProperties.Name="Restore Detail Inspector"
                                            ToolTip="Restore to normal width"
                                            Visibility="{Binding IsInspectorExpanded, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Text="&#xE73F;" FontFamily="Segoe MDL2 Assets" FontSize="10" />
                                    </Button>
                                    <Button Command="{Binding ToggleZone3Command}"
                                            Style="{StaticResource PanelChevronButtonStyle}"
                                            AutomationProperties.Name="Collapse Detail Inspector"
                                            ToolTip="Collapse (Ctrl+3)">
                                        <TextBlock Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="10" />
                                    </Button>
                                </StackPanel>
                            </DockPanel>
                        </Border>

                    <!-- Object header card -->
                    <Border Grid.Row="1" Padding="10,8"
                            Background="{DynamicResource Surface2Brush}"
                            Margin="4,4,4,0"
                            CornerRadius="4">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedObject}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding SelectedObject.ObjectClass, Converter={StaticResource ObjectClassToIconConverter}}"
                                       Foreground="{Binding SelectedObject.ObjectClass, Converter={StaticResource ObjectClassToIconColorConverter}}"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="24"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0" />
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding SelectedObject.Name}"
                                           Style="{StaticResource BodyTextStyle}"
                                           FontWeight="SemiBold"
                                           FontSize="14" />
                                <TextBlock Text="{Binding SelectedObject.ObjectClass}"
                                           Style="{StaticResource LabelStyle}" />
                                <TextBlock Text="{Binding SelectedObject.DistinguishedName}"
                                           Style="{StaticResource MonoStyle}"
                                           FontSize="10"
                                           MaxWidth="280"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,2,0,0">
                                    <TextBlock.ToolTip>
                                        <ToolTip Style="{StaticResource ThemedToolTipStyle}"
                                                 Content="{Binding SelectedObject.DistinguishedName}" />
                                    </TextBlock.ToolTip>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Detail content: Attributes + Group Membership tabs -->
                    <TabControl Grid.Row="2"
                                Margin="4,4,4,4">
                        <TabControl.Style>
                            <Style TargetType="TabControl" BasedOn="{StaticResource {x:Type TabControl}}">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedObject}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TabControl.Style>
                        <!-- Attributes tab -->
                        <TabItem Header="Attributes"
                                 AutomationProperties.Name="Attributes Tab">
                            <DataGrid ItemsSource="{Binding SelectedObjectAttributes}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      RowHeight="26"
                                      AutomationProperties.Name="Object Attributes">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="Attribute" Width="130">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Key, Mode=OneWay}" IsReadOnly="True" IsReadOnlyCaretVisible="True"
                                                         Background="Transparent" BorderThickness="0" Padding="4,2"
                                                         Foreground="{DynamicResource TextTertiaryBrush}" FontSize="11.5" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="Value" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Value, Mode=OneWay}" IsReadOnly="True" IsReadOnlyCaretVisible="True"
                                                         Background="Transparent" BorderThickness="0" Padding="4,2"
                                                         Foreground="{DynamicResource TextPrimaryBrush}" FontSize="11.5"
                                                         ToolTip="{Binding Value}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>

                        <!-- Group Membership tab -->
                        <TabItem Header="Groups"
                                 AutomationProperties.Name="Group Membership Tab">
                            <DockPanel>
                                <Button DockPanel.Dock="Top"
                                        Content="Show all members"
                                        Command="{Binding ShowGroupMembersCommand}"
                                        Margin="4,4,4,2"
                                        Padding="8,4"
                                        HorizontalAlignment="Left"
                                        AutomationProperties.Name="Show Group Members Button">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedObject.ObjectClass}" Value="group">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <!-- Group filter search bar -->
                                <TextBox DockPanel.Dock="Top"
                                         Text="{Binding GroupFilterText, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ThemedTextBoxStyle}"
                                         Margin="4,4,4,2"
                                         AutomationProperties.Name="Group Filter">
                                    <TextBox.Tag>
                                        <sys:String>Filter groups...</sys:String>
                                    </TextBox.Tag>
                                </TextBox>
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding FilteredGroups}"
                                         AutomationProperties.Name="Group Membership List">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding Mode=OneWay, Converter={StaticResource DnToNameConverter}}"
                                                     IsReadOnly="True" IsReadOnlyCaretVisible="True"
                                                     Background="Transparent" BorderThickness="0"
                                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                                     Padding="4,3">
                                                <TextBox.ToolTip>
                                                    <ToolTip Style="{StaticResource ThemedToolTipStyle}"
                                                             Content="{Binding}" />
                                                </TextBox.ToolTip>
                                                <TextBox.ContextMenu>
                                                    <ContextMenu Style="{StaticResource ThemedContextMenuStyle}">
                                                        <MenuItem Header="Show group members"
                                                                  Tag="{Binding}"
                                                                  Click="ShowGroupMembersFromList_Click"
                                                                  AutomationProperties.Name="Show Group Members From List" />
                                                    </ContextMenu>
                                                </TextBox.ContextMenu>
                                            </TextBox>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                </ScrollViewer>
                            </DockPanel>
                        </TabItem>

                        <!-- Permissions tab (deferred) -->
                        <TabItem Header="Permissions"
                                 AutomationProperties.Name="Permissions Tab">
                            <Grid>
                                <DataGrid ItemsSource="{Binding SelectedObjectPermissions}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="Horizontal"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          RowHeight="26"
                                          AutomationProperties.Name="Object Permissions">
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Header="Identity" Width="*" SortMemberPath="Identity">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBox Text="{Binding Identity, Mode=OneWay}" IsReadOnly="True" IsReadOnlyCaretVisible="True"
                                                             Background="Transparent" BorderThickness="0" Padding="4,2"
                                                             Foreground="{DynamicResource TextPrimaryBrush}" FontSize="11.5" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="Type" Width="60" SortMemberPath="AccessType">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding AccessType}" Padding="4,2" FontSize="11.5"
                                                               VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="{DynamicResource AccentGreenBrush}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding AccessType}" Value="Deny">
                                                                        <Setter Property="Foreground" Value="{DynamicResource AccentRedBrush}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="Permission" Width="*" SortMemberPath="Permission">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBox Text="{Binding Permission, Mode=OneWay}" IsReadOnly="True" IsReadOnlyCaretVisible="True"
                                                             Background="Transparent" BorderThickness="0" Padding="4,2"
                                                             Foreground="{DynamicResource TextPrimaryBrush}" FontSize="11.5" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="Inherited" Width="70" SortMemberPath="IsInherited">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Padding="4,2" FontSize="11.5"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="No" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsInherited}" Value="True">
                                                                        <Setter Property="Text" Value="Yes" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="Inherited From" Width="100" SortMemberPath="InheritedFrom">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBox Text="{Binding InheritedFrom, Mode=OneWay}" IsReadOnly="True" IsReadOnlyCaretVisible="True"
                                                             Background="Transparent" BorderThickness="0" Padding="4,2"
                                                             Foreground="{DynamicResource TextTertiaryBrush}" FontSize="11.5" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <!-- Empty state when no permissions loaded -->
                                <TextBlock Text="Select an object to view its permissions"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           AutomationProperties.Name="Permissions Empty State">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource CaptionStyle}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedObjectPermissions.Count}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </TabItem>
                    </TabControl>


                    </Grid>

                    <!-- Collapsed rail (40px icon strip) -->
                    <StackPanel Visibility="{Binding IsZone3Collapsed, Converter={StaticResource BoolToVisibilityConverter}}"
                                HorizontalAlignment="Center"
                                Margin="0,8,0,0">
                        <Button Command="{Binding ToggleZone3Command}"
                                Style="{StaticResource PanelChevronButtonStyle}"
                                AutomationProperties.Name="Expand Detail Inspector"
                                ToolTip="Expand (Ctrl+3)"
                                Margin="0,0,0,12">
                            <TextBlock Text="&#xE76B;" FontFamily="Segoe MDL2 Assets" FontSize="10" />
                        </Button>
                        <TextBlock Text="{Binding SelectedObject.ObjectClass, Converter={StaticResource ObjectClassToIconConverter}}"
                                   Foreground="{Binding SelectedObject.ObjectClass, Converter={StaticResource ObjectClassToIconColorConverter}}"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="18"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!--  ZONE 4 — Status Bar (Bottom, spans all columns)     -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <Border Grid.Row="1"
                Style="{StaticResource AdExplorerStatusBarStyle}">
            <DockPanel>
                <!-- Connection indicator -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Margin="0,0,16,0">
                    <Ellipse Width="8" Height="8"
                             Fill="{DynamicResource AccentGreenBrush}"
                             VerticalAlignment="Center"
                             Margin="0,0,6,0" />
                    <TextBlock Text="{Binding ActiveDomainDisplay, StringFormat='Connected: {0}'}"
                               Style="{StaticResource CaptionStyle}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <!-- Result count -->
                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding SearchResults.Count, StringFormat='{}{0} objects'}"
                           Style="{StaticResource CaptionStyle}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right" />

                <!-- Separator -->
                <Border Width="1" Background="{DynamicResource BorderSubtleBrush}"
                        Margin="8,2" DockPanel.Dock="Right" />

                <!-- Result status / timing -->
                <TextBlock Text="{Binding ResultStatus}"
                           Style="{StaticResource CaptionStyle}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           AutomationProperties.Name="Result Status" />
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
