<ui:FluentWindow x:Class="SysOpsCommander.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="{Binding Title}"
        Height="700"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Custom TitleBar -->
        <ui:TitleBar Grid.Row="0"
                     Title="{Binding Title}"
                     ShowMaximize="True"
                     ShowMinimize="True" />

        <!-- Main layout: sidebar + content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar Navigation -->
            <Border Grid.Column="0"
                    Width="220"
                    Padding="8,8"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="0,0,1,0">
                <DockPanel LastChildFill="False">
                    <!-- Main nav buttons -->
                    <StackPanel DockPanel.Dock="Top">
                        <Button Command="{Binding NavigateCommand}"
                                CommandParameter="Dashboard"
                                HorizontalContentAlignment="Left"
                                Margin="0,2"
                                Padding="12,10">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Home24" Margin="0,0,12,0" />
                                <TextBlock Text="Dashboard" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding NavigateCommand}"
                                CommandParameter="ADExplorer"
                                HorizontalContentAlignment="Left"
                                Margin="0,2"
                                Padding="12,10">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="PeopleTeam24" Margin="0,0,12,0" />
                                <TextBlock Text="AD Explorer" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding NavigateCommand}"
                                CommandParameter="Execution"
                                HorizontalContentAlignment="Left"
                                Margin="0,2"
                                Padding="12,10">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Play24" Margin="0,0,12,0" />
                                <TextBlock Text="Execution" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding NavigateCommand}"
                                CommandParameter="ScriptLibrary"
                                HorizontalContentAlignment="Left"
                                Margin="0,2"
                                Padding="12,10">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Code24" Margin="0,0,12,0" />
                                <TextBlock Text="Script Library" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding NavigateCommand}"
                                CommandParameter="AuditLog"
                                HorizontalContentAlignment="Left"
                                Margin="0,2"
                                Padding="12,10">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="ClipboardTextLtr24" Margin="0,0,12,0" />
                                <TextBlock Text="Audit Log" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Settings at the bottom -->
                    <StackPanel DockPanel.Dock="Bottom">
                        <Separator Margin="4,8" />
                        <Button Command="{Binding NavigateCommand}"
                                CommandParameter="Settings"
                                HorizontalContentAlignment="Left"
                                Margin="0,2"
                                Padding="12,10">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Settings24" Margin="0,0,12,0" />
                                <TextBlock Text="Settings" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Content Area -->
            <Border Grid.Column="1"
                    Margin="0"
                    Padding="16">
                <Grid>
                    <!-- Placeholder shown when no view is selected -->
                    <TextBlock Text="Select a view from the sidebar to get started."
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="16" />
                    <!-- Active view content renders on top of placeholder -->
                    <ContentControl Content="{Binding CurrentView}" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</ui:FluentWindow>
