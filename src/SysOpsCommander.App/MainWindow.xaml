<ui:FluentWindow x:Class="SysOpsCommander.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="{Binding Title}"
        Height="700"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Custom TitleBar -->
        <ui:TitleBar Grid.Row="0"
                     Title="{Binding Title}"
                     ShowMaximize="True"
                     ShowMinimize="True" />

        <!-- Main layout: sidebar + content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar Navigation -->
            <Border Grid.Column="0"
                    Padding="4,8"
                    Width="220">
                <StackPanel>
                    <ui:NavigationViewItem Content="Dashboard"
                                           Icon="{ui:SymbolIcon Home24}"
                                           IsActive="True"
                                           Command="{Binding NavigateCommand}"
                                           CommandParameter="Dashboard"
                                           Margin="0,2" />
                    <ui:NavigationViewItem Content="AD Explorer"
                                           Icon="{ui:SymbolIcon PeopleTeam24}"
                                           Command="{Binding NavigateCommand}"
                                           CommandParameter="ADExplorer"
                                           Margin="0,2" />
                    <ui:NavigationViewItem Content="Execution"
                                           Icon="{ui:SymbolIcon Play24}"
                                           Command="{Binding NavigateCommand}"
                                           CommandParameter="Execution"
                                           Margin="0,2" />
                    <ui:NavigationViewItem Content="Script Library"
                                           Icon="{ui:SymbolIcon Code24}"
                                           Command="{Binding NavigateCommand}"
                                           CommandParameter="ScriptLibrary"
                                           Margin="0,2" />
                    <ui:NavigationViewItem Content="Audit Log"
                                           Icon="{ui:SymbolIcon ClipboardTextLtr24}"
                                           Command="{Binding NavigateCommand}"
                                           CommandParameter="AuditLog"
                                           Margin="0,2" />

                    <!-- Spacer pushes Settings to bottom -->
                    <Separator Margin="8,16" />

                    <ui:NavigationViewItem Content="Settings"
                                           Icon="{ui:SymbolIcon Settings24}"
                                           Command="{Binding NavigateCommand}"
                                           CommandParameter="Settings"
                                           Margin="0,2" />
                </StackPanel>
            </Border>

            <!-- Content Area -->
            <Border Grid.Column="1"
                    Margin="4,0,8,8"
                    Padding="16"
                    CornerRadius="8">
                <ContentControl Content="{Binding CurrentView}" />
            </Border>
        </Grid>
    </Grid>
</ui:FluentWindow>
