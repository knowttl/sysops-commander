{
    "name": "Get-InstalledSoftware",
    "description": "Lists installed software from the Windows registry. Supports filtering by name.",
    "version": "1.0.0",
    "author": "SysOps Team",
    "category": "Inventory",
    "dangerLevel": "Safe",
